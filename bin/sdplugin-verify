#!/usr/bin/env python3
"""Backwards-compat shim: `sdplugin-verify …` == `sdplugin verify …`.

Prefer `bin/sdplugin verify` / `bin/sdplugin fix` (the two modes). This alias
keeps older invocations working by injecting the `verify` subcommand.
"""
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))
from sdplugin.cli import main  # noqa: E402

if __name__ == "__main__":
    main(["verify", *sys.argv[1:]])
