#!/usr/bin/env python3
"""Thin entrypoint: run the plugin toolkit without installing it.

Usage: bin/sdplugin {verify|fix} <plugin-or-container> [--strict] [--foreign a,b]
"""
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent))
from sdplugin.cli import main  # noqa: E402

if __name__ == "__main__":
    main()
